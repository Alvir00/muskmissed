# ---- Database (REQUIRED) ----
# Get a free Postgres URL from Neon (neon.tech) or Supabase (supabase.com).
# Example (Neon): postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ---- Public site URL (REQUIRED for production) ----
# Your deployed domain, WITHOUT a trailing slash.
# After deploying, copy the URL Vercel gives you (e.g. https://your-app.vercel.app)
# and paste it here / into the Vercel env vars.
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
